{
  "name": "com.oneohm.consumer",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "type-check": "tsc --noEmit",
    "start": "react-native start",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "build:android:debug": "cd android && ./gradlew assembleDebug",
    "build:android:release": "cd android && ./gradlew assembleRelease",
    "build:android:aab": "cd android && ./gradlew bundleRelease",
    "build:android:clean": "cd android && ./gradlew clean",
    "setup": "node scripts/setup.js"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.2.14",
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/messaging": "^24.0.0",
    "@react-navigation/bottom-tabs": "^7.16.1",
    "@react-navigation/native": "^7.2.4",
    "@react-navigation/native-stack": "^7.15.0",
    "@tanstack/react-query": "^5.100.10",
    "@tejas96/shared": "^1.6.1",
    "axios": "^1.16.0",
    "lottie-react-native": "^7.3.8",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-blob-util": "^0.24.6",
    "react-native-gesture-handler": "^2.31.2",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-keychain": "^10.0.0",
    "react-native-paper": "^5.15.2",
    "react-native-reanimated": "^4.3.1",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.25.0",
    "react-native-svg": "^15.15.5",
    "react-native-toast-message": "^2.3.3",
    "react-native-vector-icons": "^10.3.0",
    "react-native-worklets": "^0.8.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.85.3",
    "@react-native/eslint-config": "0.85.3",
    "@react-native/jest-preset": "0.85.3",
    "@react-native/metro-config": "0.85.3",
    "@react-native/typescript-config": "0.85.3",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-native-dotenv": "^0.2.2",
    "@types/react-test-renderer": "^19.1.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "prettier": "2.8.8",
    "react-native-dotenv": "^3.4.11",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
