{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "OneOhm Carbon Titanium Design System",
  "version": "1.0.0",
  "concept": {
    "inspiration": [
      "Nothing OS",
      "Tesla Cybertruck",
      "Apple Titanium Watch",
      "Monolithic Architecture"
    ],
    "vibe": "Ultra-minimalist, industrial, executive, high-contrast, razor-sharp metallic precision",
    "themeMode": "dark",
    "targetContrastScore": "AAA (WCAG 2.1 Level AAA Compliant)"
  },
  "tokens": {
    "colors": {
      "background": {
        "root": "#08090A",
        "gradientTop": "#121316",
        "gradientBottom": "#08090A",
        "cssGradient": "linear-gradient(180deg, #121316 0%, #08090A 100%)"
      },
      "surface": {
        "base": "#121316",
        "glassBase": "rgba(255, 255, 255, 0.05)",
        "glassStrong": "rgba(255, 255, 255, 0.08)",
        "glassHover": "rgba(255, 255, 255, 0.12)",
        "borderLight": "rgba(255, 255, 255, 0.15)",
        "borderSubtle": "rgba(255, 255, 255, 0.08)",
        "navBackdrop": "rgba(8, 9, 10, 0.88)"
      },
      "brand": {
        "primary": "#76C044",
        "primaryGlow": "rgba(118, 192, 68, 0.25)",
        "secondary": "#0D74B8",
        "accentEmerald": "#10B981"
      },
      "typography": {
        "heading": "#FFFFFF",
        "bodyPrimary": "#E4E4E7",
        "bodySecondary": "#A1A1AA",
        "muted": "#71717A",
        "disabled": "#52525B",
        "inverse": "#08090A"
      },
      "status": {
        "success": "#10B981",
        "successBg": "rgba(16, 185, 129, 0.15)",
        "warning": "#F59E0B",
        "warningBg": "rgba(245, 158, 11, 0.15)",
        "error": "#EF4444",
        "errorBg": "rgba(239, 68, 68, 0.15)",
        "info": "#3B82F6",
        "infoBg": "rgba(59, 130, 246, 0.15)"
      },
      "ambientLighting": {
        "orb1": {
          "color": "rgba(255, 255, 255, 0.15)",
          "cssRadial": "radial-gradient(circle, rgba(255, 255, 255, 0.15), transparent 70%)"
        },
        "orb2": {
          "color": "rgba(118, 192, 68, 0.12)",
          "cssRadial": "radial-gradient(circle, rgba(118, 192, 68, 0.12), transparent 70%)"
        }
      }
    },
    "typography": {
      "fontFamily": {
        "sans": [
          "Inter",
          "system-ui",
          "-apple-system",
          "BlinkMacSystemFont",
          "Segoe UI",
          "Roboto",
          "sans-serif"
        ],
        "mono": ["JetBrains Mono", "Menlo", "Monaco", "Consolas", "monospace"]
      },
      "scale": {
        "display": {
          "fontSize": "32px",
          "lineHeight": "38px",
          "fontWeight": 900,
          "letterSpacing": "-0.03em"
        },
        "title": {
          "fontSize": "22px",
          "lineHeight": "28px",
          "fontWeight": 800,
          "letterSpacing": "-0.02em"
        },
        "headline": {
          "fontSize": "18px",
          "lineHeight": "24px",
          "fontWeight": 800,
          "letterSpacing": "-0.015em"
        },
        "subhead": {
          "fontSize": "16px",
          "lineHeight": "22px",
          "fontWeight": 700,
          "letterSpacing": "-0.01em"
        },
        "body": {
          "fontSize": "14px",
          "lineHeight": "20px",
          "fontWeight": 500,
          "letterSpacing": "0em"
        },
        "caption": {
          "fontSize": "12px",
          "lineHeight": "16px",
          "fontWeight": 600,
          "letterSpacing": "0.01em"
        },
        "micro": {
          "fontSize": "10px",
          "lineHeight": "14px",
          "fontWeight": 800,
          "letterSpacing": "0.15em",
          "textTransform": "uppercase"
        }
      }
    },
    "morphology": {
      "borderRadius": {
        "sm": "8px",
        "md": "12px",
        "lg": "16px",
        "xl": "20px",
        "2xl": "24px",
        "card": "28px",
        "pill": "9999px"
      },
      "borderWidth": {
        "default": "1px",
        "thick": "2px"
      },
      "backdropBlur": {
        "nav": "30px",
        "card": "32px",
        "modal": "40px"
      }
    },
    "shadows": {
      "innerTitanium": "inset 0 1px 1px rgba(255, 255, 255, 0.2)",
      "ambientDeep": "0 20px 40px rgba(0, 0, 0, 0.8)",
      "buttonGlow": "0 8px 25px rgba(118, 192, 68, 0.25)",
      "cardHover": "0 25px 50px -12px rgba(0, 0, 0, 0.9)"
    },
    "spacing": {
      "micro": "2px",
      "2xs": "4px",
      "xs": "8px",
      "sm": "12px",
      "md": "16px",
      "lg": "24px",
      "xl": "32px",
      "2xl": "48px",
      "3xl": "64px"
    },
    "animation": {
      "curves": {
        "snappy": "cubic-bezier(0.16, 1, 0.3, 1)",
        "smooth": "cubic-bezier(0.4, 0, 0.2, 1)",
        "bounce": "cubic-bezier(0.34, 1.56, 0.64, 1)"
      },
      "durations": {
        "fast": "150ms",
        "normal": "300ms",
        "slow": "700ms"
      }
    }
  },
  "tailwindConfigSnippet": {
    "theme": {
      "extend": {
        "colors": {
          "carbon": {
            "900": "#08090A",
            "800": "#121316",
            "700": "#1C1E24"
          },
          "titanium": {
            "border": "rgba(255, 255, 255, 0.15)",
            "glass": "rgba(255, 255, 255, 0.05)",
            "text": "#E4E4E7",
            "muted": "#A1A1AA"
          },
          "brand": {
            "primary": "#76C044",
            "secondary": "#0D74B8"
          }
        },
        "borderRadius": {
          "card": "28px"
        },
        "backdropBlur": {
          "card": "32px"
        }
      }
    }
  },
  "cssCustomProperties": [
    "--bg-root: #08090A;",
    "--bg-grad: linear-gradient(180deg, #121316 0%, #08090A 100%);",
    "--glass-card: rgba(255, 255, 255, 0.05);",
    "--glass-border: rgba(255, 255, 255, 0.15);",
    "--text-main: #FFFFFF;",
    "--text-muted: #A1A1AA;",
    "--brand-green: #76C044;",
    "--radius-card: 28px;",
    "--blur-card: 32px;"
  ]
}
